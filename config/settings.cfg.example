# ══════════════════════════════════════════════════════════════
# NEO Agent — Configuración centralizada
#
# Copia este fichero como settings.cfg y rellena tus valores:
#   cp config/settings.cfg.example config/settings.cfg
#
# settings.cfg está en .gitignore — tus claves nunca se subirán.
# ══════════════════════════════════════════════════════════════


# ─── Proveedor LLM ─────────────────────────────────────────────
# Opciones: openrouter | lmstudio | anthropic | openai | google
LLM_PROVIDER=openrouter

# ─── OpenRouter ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo. Ejemplos:
#   anthropic/claude-3.5-sonnet   ← recomendado, soporta visión
#   openai/gpt-4o                 ← soporta visión
#   meta-llama/llama-3.1-70b-instruct
#   mistralai/mistral-large
#   google/gemini-pro-1.5
LLM_MODEL=anthropic/claude-3.5-sonnet

# Nombre que aparece en tus stats de openrouter.ai (opcional)
OPENROUTER_APP_NAME=NEO Agent

# ─── LM Studio (si LLM_PROVIDER=lmstudio) ─────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_TOOL_MODE=auto          # auto | prompt
# Control de tool calling para modelos locales:
#   auto  → NEO detecta automáticamente si el modelo lo soporta
#   true  → forzar activado
#   false → forzar desactivado (modo chat, sin herramientas)
LMSTUDIO_TOOL_CALLING=auto       # auto | true | false

# ─── Ollama (si LLM_PROVIDER=ollama) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Otros proveedores ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Parámetros del modelo ─────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # IDs separados por coma. Vacío = bot público.

# ─── Voz (Whisper) ─────────────────────────────────────────────
# Tamaño del modelo Whisper para transcripción de audio.
# Más grande = más preciso pero más lento y más RAM.
# Opciones: tiny | base | small | medium | large
# Apple Silicon: instala mlx-whisper para aceleración por GPU
# CPU:           instala openai-whisper
WHISPER_MODEL=small

# ─── macOS ─────────────────────────────────────────────────────
# Calendario por defecto para crear eventos.
# Usa el nombre exacto tal como aparece en la app Calendario.
# Deja vacío para usar el primer calendario editable.
# Puedes ver tus calendarios con: "¿qué calendarios tengo?"
CALENDAR_DEFAULT=

# ─── Agente ────────────────────────────────────────────────────
# Mensajes del historial para modelos remotos (OpenRouter, OpenAI, etc.)
MEMORY_WINDOW=15
# Mensajes del historial para modelos locales (LM Studio, Ollama)
# Valor bajo para no saturar el contexto limitado de modelos locales
MEMORY_WINDOW_LOCAL=4
AGENT_VERBOSE=false              # true → muestra llamadas a herramientas
AGENT_DEBUG=false
AGENT_MAX_ITERATIONS=10
