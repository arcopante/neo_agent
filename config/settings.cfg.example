# ══════════════════════════════════════════════════════════════
# NEO Agent — Configuración centralizada
#
# Edita este fichero para cambiar el comportamiento del agente.
# NO subas este fichero a git si contiene claves reales.
# ══════════════════════════════════════════════════════════════


# ─── Proveedor LLM ─────────────────────────────────────────────
# Opciones: openrouter | lmstudio | anthropic | openai | google
LLM_PROVIDER=openrouter

# ─── OpenRouter ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de OpenRouter. Ejemplos:
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o
#   meta-llama/llama-3.1-70b-instruct
#   mistralai/mistral-large
#   google/gemini-pro-1.5
LLM_MODEL=anthropic/claude-3.5-sonnet

# Nombre que se muestra en la cabecera X-Title (opcional, para stats en openrouter.ai)
OPENROUTER_APP_NAME=NEO Agent

# ─── LM Studio (si LLM_PROVIDER=lmstudio) ─────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_TOOL_MODE=auto          # auto | prompt

# ─── Otros proveedores ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Parámetros del modelo ─────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # IDs separados por coma. Vacío = bot público.

# ─── Agente ────────────────────────────────────────────────────
MEMORY_WINDOW=20
AGENT_VERBOSE=false              # true → muestra llamadas a herramientas
AGENT_DEBUG=false
AGENT_MAX_ITERATIONS=10
